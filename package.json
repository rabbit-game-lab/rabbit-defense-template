{
  "name": "rabbit-defense",
  "private": true,
  "version": "1.0.0",
  "description": "Hidden Dojo Defense: a pixel-art ninja tower defense template for Rabbit Game Lab.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "check": "node scripts/check.mjs",
    "simulate:balance": "node scripts/simulate-balance.mjs",
    "test:rules": "rm -rf .tmp-tests && tsc --noEmit false --outDir .tmp-tests && node scripts/test-rules.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^8.0.3"
  }
}
